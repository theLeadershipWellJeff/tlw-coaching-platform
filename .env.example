# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth
NEXTAUTH_URL=https://theleadershipwell.online
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Coach Accountable
COACH_ACCOUNTABLE_API_KEY=your_ca_api_key_here
COACH_ACCOUNTABLE_BASE_URL=https://www.coachaccountable.com/api/v1

# Supabase (Project Settings → API Keys)
# URL + publishable key are public-safe. The secret key is SECRET — server only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_API_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_API_SECRET_KEY=your_supabase_secret_key_here

# Your email addresses
JEFF_FROM_EMAIL=jeff@jeffkholmes.com
JEFF_CC_EMAIL=jeff@theleadershipwell.com

# Coaching scorecard — transcript ingest + scoring
# Shared secret Zapier must send as the `x-ingest-secret` header when it POSTs a
# Plaud.ai transcript to /api/transcripts/ingest. Generate with: openssl rand -hex 32
INGEST_SECRET=generate_with_openssl_rand_hex_32
# Coach a transcript belongs to when the webhook doesn't name one (beta = Jeff).
DEFAULT_COACH_EMAIL=jeff@jeffkholmes.com
DEFAULT_COACH_NAME=Jeff H.
# Optional: override the scoring model (defaults to claude-sonnet-4-6).
# Use a stronger model for sharper judgment, e.g. claude-opus-4-8.
# SCORING_MODEL=claude-sonnet-4-6
# Optional: set to "false" to ingest without auto-scoring confident matches.
# AUTO_SCORE=true
# Optional: set to "false" to stop emailing the coach their scorecard after each
# scored session (sent to the coach's address via their Google account).
# EMAIL_SCORECARD=true
# Optional: override the prep-email generation model (defaults to claude-sonnet-4-6).
# GENERATE_MODEL=claude-sonnet-4-6
